# ==========================================
# A-Stock Agent 环境配置文件模板
# ==========================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env (Mac/Linux) 或 copy .env.example .env (Windows)
# 2. 填入你的真实 API Key
# 3. 不要将 .env 提交到 Git（已在 .gitignore 中排除）
# ==========================================


# ==========================================
# 0. 输出语言
# ==========================================
# 可选值:
# - cn: 中文输出（默认）
# - en: English output
APP_LANGUAGE=cn


# ==========================================
# 1. 核心推理模型（通过 OpenRouter）
# ==========================================
# 申请地址: https://openrouter.ai/keys
# OpenRouter 支持多种模型，性价比高，推荐使用
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# 推荐模型（根据需求选择）:
# - deepseek/deepseek-chat (DeepSeek V3，性价比极高，逻辑强，推荐)
# - anthropic/claude-3.5-sonnet (目前最强编程与逻辑模型，贵但好用)
# - google/gemini-2.0-flash-exp (速度极快，免费)
# - xiaomi/mimo-v2-flash:free (小米免费模型)
OPENAI_MODEL_NAME=deepseek/deepseek-chat


# ==========================================
# 2. 视觉分析模型（GLM-4V）
# ==========================================
# 申请地址: https://open.bigmodel.cn/
# 用于 Visual Agent（看 K 线图智能体）
# 必须配置，否则视觉分析会失败
ZHIPUAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxx


# ==========================================
# 3. 联网搜索工具（Tavily）
# ==========================================
# 申请地址: https://tavily.com/
# 用于 News Agent（舆情分析智能体）
# 免费版每月 1000 次搜索，足够使用
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx



AKSHARE_PROXY_PATCH_ENABLED=true
AKSHARE_PROXY_PATCH_TOKEN=token
AKSHARE_PROXY_PATCH_HOST=101.201.173.125
AKSHARE_PROXY_PATCH_RETRY=30
